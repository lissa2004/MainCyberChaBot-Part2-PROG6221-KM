<!-- Main window definition -->
<Window x:Class="MainCyberSecurityChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity ChatBot"
        Height="600"
        Width="900">

    <!-- Main layout container -->
    <Grid Background="#101820">

        <!-- Grid column setup -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="799*"/>
            <ColumnDefinition Width="101*"/>
        </Grid.ColumnDefinitions>

        <!-- Grid row setup -->
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#89056c"
                Margin="10,10,10,10"
                CornerRadius="15" Grid.ColumnSpan="2">
            <StackPanel VerticalAlignment="Center">

                <!-- Main title -->
                <TextBlock Text="CYBER SECURITY BOT"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="White"
                />
                <!-- Subtitle -->
                <TextBlock Text="Stay Safe In The Digital World"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Foreground="White"
                />
            </StackPanel>
        </Border>
        <!-- CHAT DISPLAY AREA -->
        <ScrollViewer x:Name="ChatScrollViewer"
              Grid.Row="1"
              Margin="10,10,10,10"
              VerticalScrollBarVisibility="Auto"
              Grid.ColumnSpan="2">

            <StackPanel x:Name="ChatPanel"/>
        </ScrollViewer>

        <!-- USER INPUT SECTION -->
        <Grid Grid.Row="2"
              Margin="10,10,10,10" Grid.ColumnSpan="2">

            <!-- Input area split into textbox and button -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <!-- Input box border styling -->
            <Border Grid.Column="0"
                 CornerRadius="15"
                 Background="#EEEEEE"
                 Margin="0,0,10,0"
                 Padding="5">
                
                <!-- Textbox where user types messages -->
                <TextBox x:Name="UserInput"
                     FontSize="16"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="Black"
                     Height="40"
                     VerticalContentAlignment="Center"
                     KeyDown="UserInput_KeyDown"   
                />
            </Border>
            
            <!-- SEND button -->
            <Button Grid.Column="1"
                 Content="SEND"
                 FontSize="16"
                 FontWeight="Bold"
                 Background="#89056c"
                 Foreground="White"
                 BorderThickness="0"   
                 Click="SendButton_Click"
                 Cursor="Hand">

                <!-- Custom button styling -->
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>

                                <!-- Custom button template -->
                                <ControlTemplate TargetType="Button">

                                    <!-- Rounded button border -->
                                    <Border x:Name="border"
                                         Background="{TemplateBinding Background}"
                                         CornerRadius="15">

                                        <!-- Displays button content -->
                                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                        />
                                    </Border>

                                    <!-- Hover effect -->
                                    <ControlTemplate.Triggers>

                                        <!-- Changes color when mouse hovers -->
                                        <Trigger Property="IsMouseOver"
                                             Value="True">
                                            <Setter TargetName="border"
                                                 Property="Background"
                                                 Value="HotPink"
                                        />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>